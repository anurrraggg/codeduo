# Server
PORT=5000

# JWT
JWT_SECRET=change_me_dev_secret
JWT_EXPIRES=2h

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/codeduo

# Gemini API (Google AI Studio free tier)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
# Retries for 429 (rate limit / quota) in adaptive generation
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BASE_DELAY_MS=800

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://codeduojs.vercel.app/api/auth/google/callback

# Production Google OAuth Redirects (Required for live environment)
FRONTEND_BASE_URL=https://codeduojs.vercel.app
WEB_REDIRECT_SUCCESS=https://codeduojs.vercel.app/oauth/callback
WEB_REDIRECT_ERROR=https://codeduojs.vercel.app/login

# Frontend base URLs (optional, used for CORS and fallbacks)
FRONTEND_BASE_URL=http://localhost:3000
# FRONTEND_BASE_URL_2=
# FRONTEND_ORIGINS=http://localhost:3000,https://your-frontend-domain.com

